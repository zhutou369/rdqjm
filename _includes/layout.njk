        <nav class="nav-links">
            {% set prevPost = collections.blog | getPreviousCollectionItem(page) %}
            {% set nextPost = collections.blog | getNextCollectionItem(page) %}

            <div style="flex: 1;">
            {% if prevPost %}
                <a href="{{ prevPost.url }}" class="nav-item prev">
                    <span class="nav-label">← 上一篇文章</span>
                    <span class="nav-title">{{ prevPost.data.title }}</span> 
                </a>
            {% else %}
                <div class="nav-item" style="color: #ccc; cursor: not-allowed; background: #fafafa;">
                    <span class="nav-label">← 上一篇文章</span>
                    <span class="nav-title" style="font-size:0.9rem;">已经是第一篇了</span>
                </div>
            {% endif %}
            </div>
            
            <div style="flex: 1;">
            {% if nextPost %}
                <a href="{{ nextPost.url }}" class="nav-item next">
                    <span class="nav-label">下一篇文章 →</span>
                    <span class="nav-title">{{ nextPost.data.title }}</span>
                </a> 
            {% else %}
                <div class="nav-item next" style="color: #ccc; cursor: not-allowed; background: #fafafa;">
                    <span class="nav-label">下一篇文章 →</span>
                    <span class="nav-title" style="font-size:0.9rem;">敬请期待博主更新</span>
                </div>
            {% endif %}
