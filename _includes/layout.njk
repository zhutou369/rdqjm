        :root { --main-green: #075E54; --accent-green: #128C7E; --light-green: #25D366; --bg-gray: #f0f2f5; } 
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; line-height: 1.8; color: #333; margin: 0; background: var(--bg-gray); } 
        
        .post-container { max-width: 900px; margin: 40px auto; background: #fff; padding: 45px; border-radius: 12px; box-shadow: 0 5px 25px rgba(0,0,0,0.05); } 
        
        header { text-align: center; margin-bottom: 30px; } 
        header a { color: var(--main-green); text-decoration: none; font-weight: bold; font-size: 1.2rem; margin: 0 10px; } 
        header span { color: #ccc; } 

        h1 { color: var(--main-green); border-bottom: 2px solid #eee; padding-bottom: 20px; font-size: 2rem; margin-top: 0; } 
        .article-meta { color: #999; font-size: 0.9rem; margin-bottom: 30px; } 
        
        .article-body { font-size: 1.1rem; color: #444; text-align: justify; } 
